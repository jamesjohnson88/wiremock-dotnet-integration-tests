{
  "$schema": "https://schemas.reqnroll.net/reqnroll-config-latest.json",
  "language": {
    "feature": "en"
  },
  "generator": {
    "allowDebugGeneratedFiles": false
  },
  "runtime": {
    "missingOrPendingStepsOutcome": "Error"
